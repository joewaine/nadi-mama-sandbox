# Sandbox Mode - set to "true" to use mock services instead of real APIs
SANDBOX_MODE=true

# MongoDB - use a local instance for sandbox
MONGODB_URI=mongodb://localhost:27017/nadi_sandbox

# Server
PORT=4000

# JWT
JWT_SECRET=sandbox-secret-key

# EmergePay (not needed in sandbox mode)
EMERGEPAY_OID=
EMERGEPAY_AUTH_TOKEN=
EMERGEPAY_URL=

# Breadcrumb/Upserve (not needed in sandbox mode)
BREADCRUMB_API_KEY=
BREADCRUMB_MAMNOON_USER=
BREADCRUMB_MAMNOON_PASS=
BREADCRUMB_STREET_USER=
BREADCRUMB_STREET_PASS=
BREADCRUMB_MBAR_USER=
BREADCRUMB_MBAR_PASS=
BREADCRUMB_OLO_MAMNOON_USER=
BREADCRUMB_OLO_MAMNOON_PASS=
BREADCRUMB_OLO_STREET_USER=
BREADCRUMB_OLO_STREET_PASS=
BREADCRUMB_OLO_MBAR_USER=
BREADCRUMB_OLO_MBAR_PASS=

# Twilio (not needed in sandbox mode)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (not needed in sandbox mode)
EMAIL_USER=
EMAIL_PASS=

# Shippo (not needed in sandbox mode)
SHIPPO_API_KEY=

# SevenRooms (not needed in sandbox mode)
SEVENROOMS_TOKEN=
SEVENROOMS_VENUE_GROUP_ID=
SEVENROOMS_VENUE_ID=
